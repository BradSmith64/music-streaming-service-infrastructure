# Local .terraform directories
**/.terraform/*

# .tfstate files
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Exclude all .tfvars files, which are likely to contain sensitive data.
# They should not be part of version control.
*.tfvars
*.tfvars.json

# Ignore override files as they are usually used to override resources locally and so are not checked in.
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Exclude tfplan files as they are binary output of 'terraform plan' and shouldn't be version controlled.
*.tfplan
